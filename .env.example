# Supabase — copy this file to .env.local and fill in the values.
# Get them from your Supabase dashboard: Project Settings → API.
# .env.local is gitignored: never commit real keys.

# Public project URL (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon / publishable key (safe to expose client-side, protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, never prefixed with NEXT_PUBLIC, never committed.
# Only needed for privileged server operations; leave empty until required.
SUPABASE_SERVICE_ROLE_KEY=
